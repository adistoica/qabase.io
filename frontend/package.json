    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.5",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "@lucide/svelte": "^1.16.0",
    "@supabase/supabase-js": "^2.38.0",
    "bits-ui": "^1.0.0-next.65",
